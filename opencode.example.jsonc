{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "stepfun": {
      "npm": "@ai-sdk/openai-compatible",
      "api": "https://api.stepfun.com/step_plan/v1",
      "env": ["STEPFUN_API_KEY"],
      "options": {
        "apiKey": "YOUR_STEPFUN_API_KEY_HERE"
      },
      "models": {
        "step-3.7-flash": {
          "id": "step-3.7-flash",
          "name": "Step 3.7 Flash",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "stepfun/step-3.7-flash",
  "small_model": "stepfun/step-3.7-flash",
  "mcp": {
    "zhongwen-language-checker-v4.0.0": {
      "type": "local",
      "command": ["node", "C:\\Users\\Administrator\\.config\\opencode\\mcp\\check_language.mjs"],
      "enabled": true,
      "version": "4.0.0"
    }
  },
  "instructions": ["chinese-rules.md"],
  "default_agent": "zhongwen-agent-v4.0.0"
}
